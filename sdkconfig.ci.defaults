#
# CI overrides (merged after sdkconfig.defaults)
# Disables secure boot / flash encryption for GitHub Actions builds
#

CONFIG_COMPILER_OPTIMIZATION_SIZE=y

# CI partition table (larger factory app slot)
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="partitions.csv"

# Smaller TLS cert bundle for CI image size
# CONFIG_MBEDTLS_CERTIFICATE_BUNDLE_DEFAULT_FULL is not set
CONFIG_MBEDTLS_CERTIFICATE_BUNDLE_DEFAULT_CMN=y

# HTTPS server not used in CI (web_server runs HTTP-only)
# CONFIG_ESP_HTTPS_SERVER_ENABLE is not set

# Disable secure boot / signing (no keys in CI)
# CONFIG_SECURE_BOOT is not set
# CONFIG_SECURE_BOOT_V2_ENABLED is not set
# CONFIG_SECURE_BOOT_BUILD_SIGNED_BINARIES is not set
# CONFIG_SECURE_SIGNED_ON_UPDATE is not set

# Disable flash encryption
# CONFIG_SECURE_FLASH_ENC_ENABLED is not set

# Disable NVS encryption (no keys provisioned in CI)
# CONFIG_NVS_ENCRYPTION is not set

# Disable OTA rollback (requires secure boot efuse state)
# CONFIG_BOOTLOADER_APP_ROLLBACK_ENABLE is not set

# TLS client-only (HTTPS server disabled in CI)
# CONFIG_MBEDTLS_TLS_SERVER_AND_CLIENT is not set
CONFIG_MBEDTLS_TLS_CLIENT_ONLY=y

# Drop TLS 1.3 for CI image size
# CONFIG_MBEDTLS_SSL_PROTO_TLS1_3 is not set

# Trim curves; security_manager uses SECP256R1
# CONFIG_MBEDTLS_ECP_DP_SECP384R1_ENABLED is not set
# CONFIG_MBEDTLS_ECP_DP_CURVE25519_ENABLED is not set

# security_manager still needs X509 write APIs
CONFIG_MBEDTLS_X509_CRT_WRITE_C=y
CONFIG_MBEDTLS_X509_CSR_WRITE_C=y
CONFIG_MBEDTLS_HKDF_C=y
CONFIG_MBEDTLS_AES_C=y

# Smaller logs in CI
# CONFIG_LOG_DEFAULT_LEVEL_INFO is not set
CONFIG_LOG_DEFAULT_LEVEL_WARN=y
CONFIG_LOG_MAXIMUM_LEVEL_WARN=y